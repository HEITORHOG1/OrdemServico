{
  "AllowedHosts": "*",
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ordemservico-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] [{TenantId}] [{UsuarioId}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithEnvironmentName"]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5044",
      "https://localhost:7067",
      "http://localhost:5100",
      "http://localhost:5104",
      "http://localhost:5106",
      "http://localhost:5110",
      "http://localhost:5111"
    ]
  },
  "Auth": {
    "ApiKey": ""
  },
  "Jwt": {
    "SecretKey": "DEVELOPMENT-KEY-CHANGE-IN-PRODUCTION-MIN-32-CHARS!!",
    "Issuer": "OrdemServicoApi",
    "Audience": "OrdemServicoApp",
    "ExpiracaoMinutos": 60,
    "RefreshExpiracaoDias": 7
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=os_db;Uid=root;Pwd=root;",
    "RedisConnection": ""
  }
}
