@using Microsoft.AspNetCore.Components.Authorization
@inject Web.ViewModels.Auth.LoginViewModel LoginVM
@inject NavigationManager Navigation

<div class="sidebar-brand">
    <div class="brand-icon">
        <span class="material-icons">build_circle</span>
    </div>
    <div class="brand-text">
        <span class="brand-name">OS Web</span>
        <span class="brand-sub">Ordem de Servico</span>
    </div>
</div>

<input type="checkbox" title="Menu de navegacao" aria-label="Alternar menu de navegacao" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-section-label">PRINCIPAL</div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="material-icons nav-icon">dashboard</span>
                <span>Painel</span>
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="ordens-servico/lista">
                <span class="material-icons nav-icon">assignment</span>
                <span>Ordens de Servico</span>
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="ordens-servico">
                <span class="material-icons nav-icon">add_circle_outline</span>
                <span>Nova OS</span>
            </NavLink>
        </div>

        <div class="nav-section-label">CADASTROS</div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="clientes">
                <span class="material-icons nav-icon">people</span>
                <span>Clientes</span>
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="equipamentos">
                <span class="material-icons nav-icon">devices</span>
                <span>Equipamentos</span>
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-section-label">CONTA</div>

                <div class="nav-item px-3">
                    <div class="nav-user-info">
                        <span class="material-icons nav-icon">account_circle</span>
                        <div class="nav-user-detail">
                            <span class="nav-user-name">@context.User.FindFirst("email")?.Value</span>
                            <span class="nav-user-role">@context.User.FindFirst("role")?.Value</span>
                        </div>
                    </div>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link" href="#" @onclick="HandleLogout" @onclick:preventDefault>
                        <span class="material-icons nav-icon">logout</span>
                        <span>Sair</span>
                    </a>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private async Task HandleLogout()
    {
        await LoginVM.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
